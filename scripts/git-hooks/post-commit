#!/bin/sh

set -eu

if [ "${PAGESTATE_SKIP_PRIVATE_DOCS_HOOK:-}" = "1" ]; then
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
PRIVATE_DOCS_DIR="$(git config --get pagestate.privateDocsDir || true)"

if [ -z "$PRIVATE_DOCS_DIR" ]; then
  PRIVATE_DOCS_DIR="docs-private"
fi

case "$PRIVATE_DOCS_DIR" in
  /*|?:/*) PRIVATE_REPO="$PRIVATE_DOCS_DIR" ;;
  *) PRIVATE_REPO="$ROOT/$PRIVATE_DOCS_DIR" ;;
esac

if [ ! -d "$PRIVATE_REPO/.git" ]; then
  exit 0
fi

if [ -z "$(git -C "$PRIVATE_REPO" status --porcelain)" ]; then
  exit 0
fi

PUBLIC_HASH="$(git rev-parse --short HEAD)"
PUBLIC_MESSAGE="$(git log -1 --pretty=%s)"

git -C "$PRIVATE_REPO" add -A

if git -C "$PRIVATE_REPO" diff --cached --quiet; then
  exit 0
fi

git -C "$PRIVATE_REPO" commit -m "Sync private docs after public commit $PUBLIC_HASH: $PUBLIC_MESSAGE"
